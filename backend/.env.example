SSH_HOST=172.18.164.28
SSH_PORT=22
SSH_USER=root
SSH_KEY_PATH=./keys/3cx_rsa

LOGS_PATH=/var/lib/3cxpbx/Instance1/Data/Logs
LOG_POLL_INTERVAL=5000

NODE_EXPORTER_URL=http://172.18.164.28:9100/metrics

PORT=3001
NODE_ENV=development
MOCK_MODE=true

DB_PATH=./data/olam.db

# Override absoluto del binario SIPp (usado en deploy con Cygwin en Windows).
# Si está vacío, cae al default por plataforma (sipp.exe en Win, sipp en Linux).
# En .35 con Cygwin: C:\Users\lamda\cygwin64\home\lamda\sipp-3.7.3\sipp.exe
SIPP_BIN=

# En Windows con Cygwin: ruta al directorio cygwin64\bin que contiene
# cygwin1.dll y demás dependencias de sipp.exe. El shell de Cygwin agrega
# esta ruta a su PATH, pero `child_process.spawn` desde Node hereda solo
# el PATH del sistema Windows — sin esto SIPp arranca y muere por DLL
# faltante antes de escribir el _statistics.csv.
# En .35: C:\Users\lamda\cygwin64\bin
CYGWIN_BIN_PATH=

# Lista de extensiones válidas del 3CX, separadas por coma (BLOCK-01).
# Si está vacío, el validador permite cualquier extensión que pase el regex
# de seguridad — solo aceptable en dev local. En producción setear siempre.
VALID_EXTENSIONS=

# Credenciales de la extensión SIP que SIPp usa para autenticarse
# contra el 3CX (digest auth). El 3CX devuelve 407 si no se setean.
# Username = número de la extensión (ej. "999"). Si están vacíos, SIPp
# corre sin auth y el 3CX rechaza con 407.
SIPP_AUTH_USER=
SIPP_AUTH_PASS=

SLACK_WEBHOOK_URL=
JWT_SECRET=cambiar_en_produccion
