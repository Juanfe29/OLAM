<?xml version="1.0" encoding="ISO-8859-1" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">

<!--
  UAS auto-answer scenario para load testing.

  Diseñado para correr en paralelo al UAC para que el 3CX haga B2BUA real:
    UAC :5060 -> 3CX (.33) -> outbound rule -> trunk UAS -> UAS :5070 (este scenario)

  El UAS recibe el INVITE ruteado por el 3CX, lo contesta con 200 OK
  inmediatamente, mantiene la llamada con audio RTP G.711, y termina
  cuando recibe BYE del 3CX (originado por el UAC al cerrar).

  Sin esto, el destino del test sería una extensión real (single-line)
  o una queue/IVR — todos con sus propios límites distintos al SC256.
-->
<scenario name="UAS auto-answer for load test">

  <recv request="INVITE">
    <action>
      <ereg regexp="sip:([^@]*)@" search_in="hdr" header="To:" assign_to="1"/>
    </action>
  </recv>

  <send>
    <![CDATA[

      SIP/2.0 100 Trying
      [last_Via:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: <sip:[local_ip]:[local_port];transport=[transport]>
      Content-Length: 0

    ]]>
  </send>

  <send>
    <![CDATA[

      SIP/2.0 180 Ringing
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTagUAS[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: <sip:[local_ip]:[local_port];transport=[transport]>
      Content-Length: 0

    ]]>
  </send>

  <send retrans="500">
    <![CDATA[

      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTagUAS[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: <sip:[local_ip]:[local_port];transport=[transport]>
      Content-Type: application/sdp
      Content-Length: [len]

      v=0
      o=user1 53655765 2353687637 IN IP[local_ip_type] [local_ip]
      s=-
      c=IN IP[media_ip_type] [media_ip]
      t=0 0
      m=audio [media_port] RTP/AVP 0
      a=rtpmap:0 PCMU/8000

    ]]>
  </send>

  <recv request="ACK" rtd="true" crlf="true"/>

  <!--
    El UAC mantiene la llamada con su <pause/> y luego envía BYE.
    El UAS solo espera el BYE — no genera tráfico él mismo.
  -->
  <recv request="BYE"/>

  <send>
    <![CDATA[

      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: <sip:[local_ip]:[local_port];transport=[transport]>
      Content-Length: 0

    ]]>
  </send>

  <ResponseTimeRepartition value="10, 20, 30, 40, 50, 100, 150, 200"/>
  <CallLengthRepartition value="10, 50, 100, 500, 1000, 5000, 10000"/>

</scenario>
