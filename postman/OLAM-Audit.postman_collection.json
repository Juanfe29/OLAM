                ]
              }
            }
          ]
        },
        {
          "name": "GET History · paginado (limit=5, offset=0)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/history?limit=5&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["api", "history"],
              "query": [
                { "key": "limit",  "value": "5" },
                { "key": "offset", "value": "0" }
              ]
            },
            "description": "Paginación custom. El backend clampa `limit` a máx 200."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
