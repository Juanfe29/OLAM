        {
          "name": "GET History (default 50)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/history", "host": ["{{baseUrl}}"], "path": ["api", "history"] },
            "description": "Lista las últimas pruebas (default limit=50, offset=0)."
